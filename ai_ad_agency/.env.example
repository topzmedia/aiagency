# =============================================================================
# AI AD AGENCY — Environment Variables
# Copy this file to .env and fill in your API keys.
# The system will read these automatically at startup.
# =============================================================================

# ---- LLM Provider ----
# OpenAI (required for hook, script, caption generation)
OPENAI_API_KEY=sk-...

# Alternative: Together AI (OpenAI-compatible)
# TOGETHER_API_KEY=...
# Set provider=together and base_url in app_config.json

# Alternative: Groq (very fast, OpenAI-compatible)
# GROQ_API_KEY=gsk_...
# Set provider=groq and base_url in app_config.json

# ---- Talking Avatar Provider ----
# HeyGen (primary avatar provider — talking actor videos)
HEYGEN_API_KEY=...

# Tavus (alternative avatar provider)
# TAVUS_API_KEY=...

# D-ID (alternative avatar provider)
# DID_API_KEY=...

# ---- Image Generation ----
# OpenAI DALL-E 3 (uses the same OPENAI_API_KEY above)
# If using Stability AI:
STABILITY_API_KEY=sk-...

# ---- Video / B-Roll Generation ----
# Runway Gen-3 Alpha
RUNWAY_API_KEY=...

# Pika Labs (alternative)
# PIKA_API_KEY=...

# Kling (alternative)
# KLING_API_KEY=...

# ---- Voice Synthesis ----
# ElevenLabs (standalone TTS, used when avatar provider doesn't handle voice)
ELEVENLABS_API_KEY=...

# =============================================================================
# NOTES:
# - Without API keys, the system uses Mock providers (still runs end-to-end)
# - Mock providers generate placeholder files so you can test the full pipeline
# - Set provider=mock in app_config.json to force mock mode
# - The LLM provider (OpenAI) is the most critical — hooks/scripts require it
# - HeyGen is the primary talking actor provider — set it up first
# =============================================================================
